{"title":"Nos Publications","markdown":{"yaml":{"title":"Nos Publications","listing":{"id":"pubslist","contents":"pubs","type":"grid","grid-columns":4,"sort":"date desc","page-size":12,"fields":["image","title","date","categories","pdf","pubtype"],"filter-ui":false,"categories":false,"image-height":"100px"}},"containsRefs":false,"markdown":"\n\n\n<div class=\"pubs-toolbar d-flex flex-wrap gap-2 align-items-center mb-3\">\n  <!-- search -->\n  <input id=\"pubs-search\" type=\"search\" class=\"form-control form-control-sm\"\n         placeholder=\"Rechercher des publications…\" style=\"max-width: 320px;\">\n  <!-- tags get injected here -->\n  <div id=\"pubs-tags\" class=\"d-flex flex-wrap gap-1 ms-auto\"></div>\n</div>\n\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function () {\n  const root = document.getElementById('listing-pubslist');\n  if (!root) return;\n\n  const cards = root.querySelectorAll('.quarto-grid-item.card');\n\n  // --- Setup: extract metadata, build PDF buttons ---\n  cards.forEach(card => {\n    const table = card.querySelector('.card-other-values');\n    const pdfCell = table?.querySelector('td.pdf');\n    const typeCell = table?.querySelector('td.pubtype');\n\n    const pdfUrl  = pdfCell ? pdfCell.textContent.trim() : '';\n    const pubtype = typeCell ? typeCell.textContent.trim() : '';\n\n    if (pubtype) card.setAttribute('data-pubtype', pubtype);\n\n    const body  = card.querySelector('.card-body');\n    const title = body?.querySelector('.card-title');\n    let metaRow = body?.querySelector('.card-meta-row');\n\n    if (!metaRow && body && title) {\n      metaRow = document.createElement('div');\n      metaRow.className = 'card-meta-row d-flex justify-content-between align-items-center mb-2';\n      body.insertBefore(metaRow, title);\n    }\n\n    if (metaRow && pdfUrl) {\n      const btn = document.createElement('a');\n      btn.className = 'btn btn-sm btn-pdf stretched-link-fix';\n      btn.href = pdfUrl;\n      btn.setAttribute('download', '');\n      btn.textContent = 'PDF';\n      metaRow.prepend(btn);\n    }\n\n    const dateEl = card.querySelector('.listing-date');\n    if (metaRow && dateEl) {\n      dateEl.classList.add('text-muted', 'small', 'ms-auto');\n      metaRow.appendChild(dateEl);\n    }\n\n    if (table) table.remove();\n  });\n\n  // --- Filter state (sem toggle WP/PB — todas publicações visíveis) ---\n  let selectedTag = null;\n  let searchText = '';\n\n  const search = document.getElementById('pubs-search');\n  const tagBar = document.getElementById('pubs-tags');\n\n  // --- Get wrapper element (.g-col-1) for a card ---\n  function getWrapper(card) {\n    return card.closest('.g-col-1') || card;\n  }\n\n  // --- FLIP Animation helper ---\n  function animateCards(callback) {\n    const positions = new Map();\n    cards.forEach(card => {\n      const wrapper = getWrapper(card);\n      if (wrapper.style.display !== 'none') {\n        const rect = wrapper.getBoundingClientRect();\n        positions.set(wrapper, { x: rect.left, y: rect.top });\n      }\n    });\n\n    callback();\n\n    cards.forEach(card => {\n      const wrapper = getWrapper(card);\n      if (wrapper.style.display !== 'none') {\n        const oldPos = positions.get(wrapper);\n        if (oldPos) {\n          const newRect = wrapper.getBoundingClientRect();\n          const deltaX = oldPos.x - newRect.left;\n          const deltaY = oldPos.y - newRect.top;\n\n          if (deltaX !== 0 || deltaY !== 0) {\n            wrapper.style.transform = `translate(${deltaX}px, ${deltaY}px)`;\n            wrapper.style.transition = 'none';\n\n            requestAnimationFrame(() => {\n              requestAnimationFrame(() => {\n                wrapper.style.transition = 'transform 0.35s ease-out, opacity 0.3s ease';\n                wrapper.style.transform = '';\n              });\n            });\n          }\n        } else {\n          wrapper.style.opacity = '0';\n          wrapper.style.transition = 'none';\n          requestAnimationFrame(() => {\n            requestAnimationFrame(() => {\n              wrapper.style.transition = 'transform 0.35s ease-out, opacity 0.3s ease';\n              wrapper.style.opacity = '';\n            });\n          });\n        }\n      }\n    });\n  }\n\n  // --- Core filter logic (sem filtro de tipo) ---\n  function applyFilters(animate = true) {\n    const doFilter = () => {\n      cards.forEach(card => {\n        const wrapper = getWrapper(card);\n        let tagOk = true;\n        if (selectedTag) {\n          tagOk = Array.from(card.querySelectorAll('.listing-category'))\n            .some(cat => (cat.textContent || '').trim() === selectedTag);\n        }\n        let searchOk = true;\n        if (searchText) {\n          const hay = [\n            card.querySelector('.listing-title')?.textContent || '',\n            ...Array.from(card.querySelectorAll('.listing-category')).map(x => x.textContent || '')\n          ].join(' ').toLowerCase();\n          searchOk = hay.includes(searchText);\n        }\n        wrapper.style.display = (tagOk && searchOk) ? '' : 'none';\n      });\n    };\n\n    if (animate) {\n      animateCards(doFilter);\n    } else {\n      doFilter();\n    }\n  }\n\n  // --- Build tag pills ---\n  const tagSet = new Set();\n  cards.forEach(card => {\n    card.querySelectorAll('.listing-category').forEach(cat => {\n      const label = (cat.textContent || '').trim();\n      if (label) tagSet.add(label);\n    });\n  });\n\n  tagBar.innerHTML = '';\n  const allBtn = document.createElement('button');\n  allBtn.className = 'btn btn-sm btn-outline-secondary active';\n  allBtn.textContent = 'Toutes les étiquettes';\n  allBtn.dataset.tag = '';\n  tagBar.appendChild(allBtn);\n\n  [...tagSet].sort((a, b) => a.localeCompare(b)).forEach(t => {\n    const b = document.createElement('button');\n    b.className = 'btn btn-sm btn-outline-secondary';\n    b.textContent = t;\n    b.dataset.tag = t;\n    tagBar.appendChild(b);\n  });\n\n  tagBar.querySelectorAll('button').forEach(b => {\n    b.addEventListener('click', () => {\n      tagBar.querySelectorAll('button').forEach(x => x.classList.remove('active'));\n      b.classList.add('active');\n      selectedTag = b.dataset.tag || null;\n      applyFilters();\n    });\n  });\n\n  // --- Search handler ---\n  if (search) {\n    search.addEventListener('input', () => {\n      searchText = (search.value || '').trim().toLowerCase();\n      applyFilters();\n    });\n  }\n\n  // --- Initial render (todas visíveis) ---\n  applyFilters(false);\n});\n</script>\n","srcMarkdownNoYaml":"\n\n\n<div class=\"pubs-toolbar d-flex flex-wrap gap-2 align-items-center mb-3\">\n  <!-- search -->\n  <input id=\"pubs-search\" type=\"search\" class=\"form-control form-control-sm\"\n         placeholder=\"Rechercher des publications…\" style=\"max-width: 320px;\">\n  <!-- tags get injected here -->\n  <div id=\"pubs-tags\" class=\"d-flex flex-wrap gap-1 ms-auto\"></div>\n</div>\n\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function () {\n  const root = document.getElementById('listing-pubslist');\n  if (!root) return;\n\n  const cards = root.querySelectorAll('.quarto-grid-item.card');\n\n  // --- Setup: extract metadata, build PDF buttons ---\n  cards.forEach(card => {\n    const table = card.querySelector('.card-other-values');\n    const pdfCell = table?.querySelector('td.pdf');\n    const typeCell = table?.querySelector('td.pubtype');\n\n    const pdfUrl  = pdfCell ? pdfCell.textContent.trim() : '';\n    const pubtype = typeCell ? typeCell.textContent.trim() : '';\n\n    if (pubtype) card.setAttribute('data-pubtype', pubtype);\n\n    const body  = card.querySelector('.card-body');\n    const title = body?.querySelector('.card-title');\n    let metaRow = body?.querySelector('.card-meta-row');\n\n    if (!metaRow && body && title) {\n      metaRow = document.createElement('div');\n      metaRow.className = 'card-meta-row d-flex justify-content-between ali