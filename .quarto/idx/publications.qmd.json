transition = 'transform 0.35s ease-out, opacity 0.3s ease';\n                wrapper.style.transform = '';\n              });\n            });\n          }\n        } else {\n          wrapper.style.opacity = '0';\n          wrapper.style.transition = 'none';\n          requestAnimationFrame(() => {\n            requestAnimationFrame(() => {\n              wrapper.style.transition = 'transform 0.35s ease-out, opacity 0.3s ease';\n              wrapper.style.opacity = '';\n            });\n          });\n        }\n      }\n    });\n  }\n\n  // --- Core filter logic (sem filtro de tipo) ---\n  function applyFilters(animate = true) {\n    const doFilter = () => {\n      cards.forEach(card => {\n        const wrapper = getWrapper(card);\n        let tagOk = true;\n        if (selectedTag) {\n          tagOk = Array.from(card.querySelectorAll('.listing-category'))\n            .some(cat => (cat.textContent || '').trim() === selectedTag);\n        }\n        let searchOk = true;\n        if (searchText) {\n          const hay = [\n            card.querySelector('.listing-title')?.textContent || '',\n            ...Array.from(card.querySelectorAll('.listing-category')).map(x => x.textContent || '')\n          ].join(' ').toLowerCase();\n          searchOk = hay.includes(searchText);\n        }\n        wrapper.style.display = (tagOk && searchOk) ? '' : 'none';\n      });\n    };\n\n    if (animate) {\n      animateCards(doFilter);\n    } else {\n      doFilter();\n    }\n  }\n\n  // --- Build tag pills ---\n  const tagSet = new Set();\n  cards.forEach(card => {\n    card.querySelectorAll('.listing-category').forEach(cat => {\n      const label = (cat.textContent || '').trim();\n      if (label) tagSet.add(label);\n    });\n  });\n\n  tagBar.innerHTML = '';\n  const allBtn = document.createElement('button');\n  allBtn.className = 'btn btn-sm btn-outline-secondary active';\n  allBtn.textContent = 'Toutes les étiquettes';\n  allBtn.dataset.tag = '';\n  tagBar.appendChild(all